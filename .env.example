# Mnemo — environment configuration template.
# All variables use the MNEMO_ prefix. Copy to .env and adjust.

# --- Backend selection ----------------------------------------------------
MNEMO_STORE=chroma          # chroma | lance
MNEMO_PIPELINE=default      # default | llamaindex

# --- Embedding model ------------------------------------------------------
MNEMO_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Persistence ----------------------------------------------------------
MNEMO_PERSIST_DIR=./data

# --- Multi-tenant namespace ------------------------------------------------
# Each `(project, environment)` pair gets its own pair of collections,
# named `<3-digit project id>_<env>_<axis>`. The project registry at
# <persist-dir>/projects.json maps human slugs to stable 3-digit IDs.
MNEMO_PROJECT=demo-project        # lowercase slug, [a-z0-9-], max 32 chars
MNEMO_ENVIRONMENT=dev             # one of: dev | col | pre | prd

# --- Collection axes -------------------------------------------------------
MNEMO_SPECS_COLLECTION=specs
MNEMO_BUGS_COLLECTION=bug_memory

# --- Source paths (read by the agentic ingestion CLIs) -------------------
# Point these at your local mirror of Wiki/ADO exports — or at any folder
# tree that matches the loader's expected layout (markdown for specs,
# JSON for bugs). See src/mnemo/ingestion/*.py for the schemas.
MNEMO_SPECS_SOURCE_DIR=./examples/specs
MNEMO_BUGS_SOURCE_DIR=./examples/bugs

# --- Chunking -------------------------------------------------------------
MNEMO_CHUNK_SIZE=512
MNEMO_CHUNK_OVERLAP=64

# --- Retrieval ------------------------------------------------------------
MNEMO_TOP_K=5

# --- Family aliases --------------------------------------------------------
# `--agentic <family>` resolves to whichever short-name / full id you pin
# here. Bump one line to upgrade an entire family across all Mnemo
# invocations — no code changes needed.
MNEMO_FAMILY_GPT=gpt-5-mini
MNEMO_FAMILY_CLAUDE=claude-sonnet-4-6
MNEMO_FAMILY_SONNET=claude-sonnet-4-6
MNEMO_FAMILY_OPUS=claude-opus-4-6

# --- GitHub Models (curl runtime, opt-in) ----------------------------------
# Used when --agentic is passed with a model name. Default for `--agentic`
# (bare) is gpt-5-mini, which is the cheapest reasoning model.
#
# IMPORTANT — the token is NOT stored here. Export it in your shell:
#   MNEMO_GHMODELS_TOKEN=<PAT>   (preferred, Mnemo-scoped)
#   GH_TOKEN=<PAT>                (gh CLI standard)
#   GITHUB_TOKEN=<PAT>            (CI standard, last resort)
# The PAT must have scope `models:read`.
MNEMO_GHMODELS_ENDPOINT=https://models.github.ai/inference/chat/completions
MNEMO_GHMODELS_CATALOG_ENDPOINT=https://models.github.ai/catalog/models
MNEMO_GHMODELS_MODEL=openai/gpt-5-mini
MNEMO_GHMODELS_REASONING_EFFORT=medium      # minimal | low | medium | high
MNEMO_GHMODELS_MAX_COMPLETION_TOKENS=6000
MNEMO_GHMODELS_TIMEOUT_SECONDS=180

# --- Subprocess Copilot CLI (alternative runtime, used by --agentic copilot)
# Auto-model mode (Copilot decides). No per-model control here; use the
# GitHub Models runtime above if you need explicit model selection.
#
# MNEMO_COPILOT_BIN=copilot           # executable on PATH or absolute path
# MNEMO_COPILOT_ARGS=--no-stream      # space-separated extra args to the CLI
# MNEMO_COPILOT_STDIN=1               # "1" → prompt via stdin, "0" → as positional arg
# MNEMO_COPILOT_TIMEOUT=180           # per-call timeout in seconds
